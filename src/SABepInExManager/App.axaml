<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SABepInExManager.Bootstrap"
             xmlns:local="using:SABepInExManager"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://SABepInExManager/Styles/DialogStyles.axaml"/>
        <StyleInclude Source="avares://SABepInExManager/Styles/AppShellStyles.axaml"/>
    </Application.Styles>
</Application>

