<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#1F2328"/>
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#DCE3EC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <Style Selector="TextBlock.secondary-text">
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Border.setting-row">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#E1E6ED"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="TextBlock.setting-title">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#111827"/>
    </Style>

    <Style Selector="TextBlock.setting-desc">
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Border.shell-nav-pane">
        <Setter Property="Background" Value="#F4F7FB"/>
        <Setter Property="BorderBrush" Value="#DCE3EC"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <Style Selector="TextBox.search-box">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#D1D9E3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="32,7,12,7"/>
    </Style>

    <Style Selector="ListBox.shell-nav-list">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.shell-nav-list ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="0,1"/>
    </Style>

    <Style Selector="ListBox.shell-nav-list ListBoxItem:selected">
        <Setter Property="Background" Value="#DCEBFA"/>
    </Style>

    <Style Selector="ListBox.shell-nav-list ListBoxItem:pointerover">
        <Setter Property="Background" Value="#EAF2FB"/>
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#14181F"/>
    </Style>

    <Style Selector="Button.setting-inline-action">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="18,6"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="BorderBrush" Value="#1D4ED8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#1D4ED8"/>
        <Setter Property="BorderBrush" Value="#1E40AF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#1E40AF"/>
        <Setter Property="BorderBrush" Value="#1E3A8A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <Style Selector="Button.action-button.primary-action">
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="BorderBrush" Value="#1D4ED8"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="BorderBrush" Value="#1D4ED8"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pointerover">
        <Setter Property="Background" Value="#1D4ED8"/>
        <Setter Property="BorderBrush" Value="#1E40AF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pointerover TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1D4ED8"/>
        <Setter Property="BorderBrush" Value="#1E40AF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pressed">
        <Setter Property="Background" Value="#1E40AF"/>
        <Setter Property="BorderBrush" Value="#1E3A8A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pressed TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.primary-action:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1E40AF"/>
        <Setter Property="BorderBrush" Value="#1E3A8A"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.secondary-action">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="Foreground" Value="#334155"/>
    </Style>

    <Style Selector="Button.warning-action">
        <Setter Property="Background" Value="#F59E0B"/>
        <Setter Property="BorderBrush" Value="#D97706"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action">
        <Setter Property="Background" Value="#DC2626"/>
        <Setter Property="BorderBrush" Value="#B91C1C"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#DC2626"/>
        <Setter Property="BorderBrush" Value="#B91C1C"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pointerover">
        <Setter Property="Background" Value="#B91C1C"/>
        <Setter Property="BorderBrush" Value="#991B1B"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pointerover TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#B91C1C"/>
        <Setter Property="BorderBrush" Value="#991B1B"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pressed">
        <Setter Property="Background" Value="#991B1B"/>
        <Setter Property="BorderBrush" Value="#7F1D1D"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pressed TextBlock">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Button.action-button.danger-action:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#991B1B"/>
        <Setter Property="BorderBrush" Value="#7F1D1D"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#1A202C"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#1A202C"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style Selector="Border.status-banner">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.status-banner.installed">
        <Setter Property="Background" Value="#ECFDF5"/>
        <Setter Property="BorderBrush" Value="#86EFAC"/>
    </Style>

    <Style Selector="Border.status-banner.missing">
        <Setter Property="Background" Value="#FFF7ED"/>
        <Setter Property="BorderBrush" Value="#FDBA74"/>
    </Style>

    <Style Selector="Border.status-banner.missing.installed">
        <Setter Property="Background" Value="#ECFDF5"/>
        <Setter Property="BorderBrush" Value="#86EFAC"/>
    </Style>

    <Style Selector="Border.stat-card">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#E2E8F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style Selector="TextBlock.stat-value">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#0F172A"/>
    </Style>

    <Style Selector="TextBlock.stat-value-small">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#0F172A"/>
    </Style>

    <Style Selector="Grid.kv-row">
        <Setter Property="ColumnSpacing" Value="12"/>
    </Style>

    <Style Selector="ListBox.nav-list ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style Selector="ListBox.nav-list ListBoxItem:selected">
        <Setter Property="Background" Value="#DBEAFE"/>
    </Style>

    <Style Selector="ListBox.nav-list ListBoxItem:pointerover">
        <Setter Property="Background" Value="#EFF6FF"/>
    </Style>
</Styles>

