<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.AboutPageView"
             x:DataType="vm:AboutPageViewModel">

    <Grid Margin="0" RowDefinitions="Auto,*" RowSpacing="12">
        <Border Grid.Row="0" Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                <TextBlock Text="{Binding AppName}" FontSize="18" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Text="{Binding Description}" Classes="secondary-text"/>
                <TextBlock Grid.Row="2" Text="{Binding License, StringFormat=License：{0}}"/>
                <TextBlock Grid.Row="3" Text="{Binding RepositoryUrl, StringFormat=GitHub：{0}}" Classes="secondary-text"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="card">
            <TextBlock Text="技术栈：AvaloniaUI · .NET · CommunityToolkit.Mvvm" Classes="secondary-text"/>
        </Border>
    </Grid>
</UserControl>

