<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.BackupPageView"
             x:DataType="vm:BackupPageViewModel">

    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
        <TextBlock Text="备份与恢复" FontSize="22" FontWeight="Bold"/>

        <TextBlock Grid.Row="1"
                   Text="备份会保存当前游戏目录下被 Mod 管理器接管的文件状态。每次创建备份都会生成一个以 Unix 时间戳命名的新快照目录，恢复时将回滚到最近一次备份。"
                   Classes="secondary-text"
                   TextWrapping="Wrap"/>

        <Border Grid.Row="2" Classes="card">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="action-button secondary-action"
                        Content="创建备份"
                        IsEnabled="{Binding HomePage.IsBepInExInstalled}"
                        Command="{Binding HomePage.CreateBaselineCommand}"/>
                <Button Classes="action-button warning-action"
                        Content="恢复备份"
                        IsEnabled="{Binding HomePage.IsBepInExInstalled}"
                        Command="{Binding HomePage.RestoreBaselineCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Classes="card">
            <TextBlock Text="后续可在此加入备份列表、快照详情、恢复预览。" Classes="secondary-text"/>
        </Border>
    </Grid>
</UserControl>

