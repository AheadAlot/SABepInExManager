<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.ConflictsPageView"
             x:DataType="vm:ConflictsPageViewModel">

    <Grid Margin="12" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <TextBlock Text="冲突预览" FontSize="22" FontWeight="Bold"/>

        <Border Grid.Row="1" Classes="card">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="action-button primary-action"
                        Content="扫描冲突"
                        IsEnabled="{Binding HomePage.IsBepInExInstalled}"
                        Command="{Binding HomePage.PreviewConflictsCommand}"/>
                <TextBlock Text="结果会写入日志页，主页仅显示摘要。" Classes="secondary-text" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card">
            <TextBlock Text="后续可在此加入按路径分组、冲突赢家/覆盖链展示。" Classes="secondary-text"/>
        </Border>
    </Grid>
</UserControl>

