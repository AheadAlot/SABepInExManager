<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.HomePageView"
             x:DataType="vm:HomePageViewModel">

    <Grid Margin="12" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <Border Grid.Row="0" Classes="status-banner missing"
                Classes.installed="{Binding IsBepInExInstalled}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding BepInExStatusText, StringFormat=BepInEx 状态：{0}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1"
                           Classes="secondary-text"
                           Text="若未安装可一键安装；已安装时可重复执行安装进行修复。"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Classes="action-button"
                        Classes.danger-action="{Binding IsBepInExInstalled}"
                        Content="{Binding InstallBepInExButtonText}"
                        Click="OnInstallBepInExClicked"
                        ToolTip.Tip="安装/修复 BepInEx"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10">
            <Border Grid.Row="0" Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Text="游戏根目录" FontWeight="SemiBold"/>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Watermark="例如: D:\SteamLibrary\steamapps\common\StudentAge"
                                 Text="{Binding GameRootPath}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Classes="action-button secondary-action"
                                    Content="选择文件夹"
                                    Click="OnPickGameRootFolderClicked"/>
                            <Button Classes="action-button primary-action"
                                    Content="自动探测"
                                    Command="{Binding DetectGameRootPathCommand}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="创意工坊路径" FontWeight="SemiBold"/>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Watermark="例如: D:\SteamLibrary\steamapps\workshop\content\1991040"
                                 Text="{Binding WorkshopContentPath}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Classes="action-button secondary-action"
                                    Content="选择文件夹"
                                    Click="OnPickWorkshopFolderClicked"/>
                            <Button Classes="action-button primary-action"
                                    Content="自动探测"
                                    Command="{Binding DetectWorkshopPathCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*">
                <Border Grid.Column="0" Classes="card">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
                        <StackPanel Grid.Row="1" Spacing="2">
                            <TextBlock Text="{Binding SelectedMod.DisplayName, FallbackValue=未选择 Mod}"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedMod.ModId, StringFormat=ID: {0}}"
                                       Classes="secondary-text"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="6">
                            <TextBlock Text="描述" FontWeight="SemiBold"/>
                            <Border Grid.Row="1"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    VerticalAlignment="Stretch"
                                    ClipToBounds="True">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding SelectedMod.Description}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding SelectedMod.ModRootPath, StringFormat=目录: {0}}"
                                   Classes="secondary-text"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Classes="card">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="action-button secondary-action"
                            Content="冲突预览"
                            IsEnabled="{Binding IsBepInExInstalled}"
                            Command="{Binding PreviewConflictsCommand}"/>
                    <Button Classes="action-button secondary-action"
                            Content="创建备份"
                            IsEnabled="{Binding IsBepInExInstalled}"
                            Command="{Binding CreateBaselineCommand}"/>
                    <Button Classes="danger-action"
                            Content="恢复备份"
                            IsEnabled="{Binding IsBepInExInstalled}"
                            Click="OnRestoreBaselineClicked"/>
                </StackPanel>

                <ListBox x:Name="LogListBox"
                         Grid.Row="1"
                         Height="160"
                         ItemsSource="{Binding Logs}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <TextBlock Text="{Binding TimestampText}" Classes="secondary-text"/>
                                <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>


