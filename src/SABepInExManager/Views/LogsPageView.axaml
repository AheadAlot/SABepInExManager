<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.LogsPageView"
             x:DataType="vm:LogsPageViewModel">

    <Grid Margin="0" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <TextBlock Grid.Row="0"
                   Text="日志会记录管理器中的关键操作与提示信息，便于排查问题和确认执行结果。清空日志不会影响已安装模组与配置。"
                   Classes="secondary-text"
                   TextWrapping="Wrap"/>

        <Border Grid.Row="1" Classes="setting-row">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="清空日志" Classes="setting-title"/>
                    <TextBlock Text="删除当前界面显示的日志记录，不影响模组安装与配置数据。"
                               Classes="setting-desc"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Classes="action-button primary-action"
                        Content="清空日志"
                        Command="{Binding HomePage.ClearLogsCommand}"
                        VerticalAlignment="Center"
                        MinWidth="100"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="2" ItemsSource="{Binding HomePage.Logs}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="{Binding TimestampText}" Classes="secondary-text"/>
                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>

