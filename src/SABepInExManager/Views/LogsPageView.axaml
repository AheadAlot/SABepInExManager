<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             x:Class="SABepInExManager.Views.LogsPageView"
             x:DataType="vm:LogsPageViewModel">

    <Grid Margin="12" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <TextBlock Text="日志" FontSize="22" FontWeight="Bold"/>

        <Border Grid.Row="1" Classes="card">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="action-button secondary-action"
                        Content="清空日志"
                        Command="{Binding HomePage.ClearLogsCommand}"/>
                <TextBlock Text="后续可扩展级别筛选、关键词搜索、导出。" Classes="secondary-text" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card">
            <ListBox ItemsSource="{Binding HomePage.Logs}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <TextBlock Text="{Binding TimestampText}" Classes="secondary-text"/>
                            <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>

