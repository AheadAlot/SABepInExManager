<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SABepInExManager.ViewModels"
        xmlns:icons="using:FluentIcons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="820"
        x:Class="SABepInExManager.Views.MainWindow"
        x:DataType="vm:ShellWindowViewModel"
        RequestedThemeVariant="Light"
        Background="#EEF3F9"
        Foreground="#1A202C"
        MinWidth="1180"
        MinHeight="760"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding AppName}">

    <Design.DataContext>
        <vm:ShellWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="280,*">
        <Border Classes="shell-nav-pane">
            <Grid RowDefinitions="Auto,Auto,*">
                <ListBox Grid.Row="2"
                         Classes="shell-nav-list"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItemViewModel">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <icons:SymbolIcon Symbol="{Binding Icon}" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="12" Margin="20,14,16,12">
            <TextBlock Text="{Binding CurrentPageTitle}" Classes="page-title"/>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}"/>

            <Border Grid.Row="2" Classes="card" Padding="12,8">
                <TextBlock Text="{Binding GlobalStatusText}" TextTrimming="CharacterEllipsis" Classes="secondary-text"/>
            </Border>
        </Grid>
    </Grid>
</Window>

