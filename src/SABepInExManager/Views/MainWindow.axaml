<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SABepInExManager.ViewModels"
        xmlns:views="using:SABepInExManager.Views"
        xmlns:behaviors="using:SABepInExManager.Behaviors"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="SABepInExManager.Views.MainWindow"
        x:DataType="vm:ShellWindowViewModel"
        RequestedThemeVariant="Light"
        Background="#F3F6FB"
        Foreground="#1A202C"
        MinWidth="1080"
        MinHeight="720"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding AppName}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:ShellWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <StyleInclude Source="avares://Xaml.Behaviors.Interactions.DragAndDrop/Styles.axaml" />

        <Style Selector="ListBox.ModsDragAndDrop">
            <Style.Resources>
                <behaviors:ModsListBoxDropHandler x:Key="ModsListBoxDropHandler" />
            </Style.Resources>
            <Setter Property="(i:Interaction.Behaviors)">
                <i:BehaviorCollectionTemplate>
                    <i:BehaviorCollection>
                        <ContextDropBehavior Handler="{StaticResource ModsListBoxDropHandler}" />
                    </i:BehaviorCollection>
                </i:BehaviorCollectionTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Border.mod-drag-handle">
            <Setter Property="(i:Interaction.Behaviors)">
                <i:BehaviorCollectionTemplate>
                    <i:BehaviorCollection>
                        <ContextDragBehavior HorizontalDragThreshold="3" VerticalDragThreshold="3" />
                    </i:BehaviorCollection>
                </i:BehaviorCollectionTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem.DraggingUp">
            <Setter Property="AdornerLayer.Adorner">
                <Template>
                    <Border BorderThickness="0 2 0 0"
                            BorderBrush="#2563EB"
                            IsHitTestVisible="False" />
                </Template>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem.DraggingDown">
            <Setter Property="AdornerLayer.Adorner">
                <Template>
                    <Border BorderThickness="0 0 0 2"
                            BorderBrush="#2563EB"
                            IsHitTestVisible="False" />
                </Template>
            </Setter>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#1A202C"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8E0EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBlock.secondary-text">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="Button.action-button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style Selector="Button.action-button.primary-action">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Button.action-button.secondary-action">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <Style Selector="Button.danger-action">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#B91C1C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Border.status-banner">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Border.status-banner.installed">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#86EFAC"/>
        </Style>

        <Style Selector="Border.status-banner.missing">
            <Setter Property="Background" Value="#FFF7ED"/>
            <Setter Property="BorderBrush" Value="#FDBA74"/>
        </Style>

        <Style Selector="Border.status-banner.missing.installed">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#86EFAC"/>
        </Style>

    </Window.Styles>

    <Grid Margin="12" ColumnDefinitions="380,*" ColumnSpacing="10">
            <Border Grid.Column="0" Classes="card">
                <Grid DataContext="{Binding HomePage}" RowDefinitions="Auto,*,Auto" RowSpacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Mod 列表（拖动排序）"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="action-button secondary-action"
                                Content="说明"
                                Click="OnShowModListHelpClicked"/>
                    </Grid>

                    <ListBox x:Name="ModsListBox"
                             Grid.Row="1"
                             Classes="ModsDragAndDrop"
                             ItemsSource="{Binding Mods}"
                             SelectedItem="{Binding SelectedMod}"
                             DoubleTapped="OnModsListDoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="8" RowSpacing="2">
                                    <CheckBox Grid.RowSpan="2"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Top"
                                              Margin="0,1,0,0"/>
                                    <Border Grid.Column="1"
                                            Grid.RowSpan="2"
                                            Classes="mod-drag-handle"
                                            Background="Transparent">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding ModId, StringFormat=ID: {0}}"
                                                       Classes="secondary-text"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="8">
                        <Button Classes="action-button primary-action"
                                 Content="刷新列表"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Center"
                                 IsEnabled="{Binding IsBepInExInstalled}"
                                 Command="{Binding RefreshModsCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="0">
                <views:HomePageView DataContext="{Binding HomePage}" />
            </Border>
    </Grid>

</Window>

