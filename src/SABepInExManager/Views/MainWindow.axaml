<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SABepInExManager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="820"
        x:Class="SABepInExManager.Views.MainWindow"
        x:DataType="vm:ShellWindowViewModel"
        RequestedThemeVariant="Light"
        Background="#F3F6FB"
        Foreground="#1A202C"
        MinWidth="1180"
        MinHeight="760"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding AppName}">

    <Design.DataContext>
        <vm:ShellWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="16" ColumnDefinitions="240,*" ColumnSpacing="12">
        <ListBox Grid.Column="0"
                 Classes="nav-list"
                 ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigationItem}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavigationItemViewModel">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="10">
            <Border Classes="card" Padding="0">
                <ContentControl Content="{Binding CurrentPageViewModel}"/>
            </Border>

            <Border Grid.Row="1" Classes="card" Padding="10,8">
                <TextBlock Text="{Binding GlobalStatusText}" TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
    </Grid>
</Window>

