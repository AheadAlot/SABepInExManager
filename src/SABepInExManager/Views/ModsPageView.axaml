<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SABepInExManager.ViewModels"
             xmlns:behaviors="using:SABepInExManager.Behaviors"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             x:Class="SABepInExManager.Views.ModsPageView"
             x:DataType="vm:ModsPageViewModel">

    <UserControl.Styles>
        <StyleInclude Source="avares://Xaml.Behaviors.Interactions.DragAndDrop/Styles.axaml" />

        <Style Selector="ListBox.ModsDragAndDrop">
            <Style.Resources>
                <behaviors:ModsListBoxDropHandler x:Key="ModsListBoxDropHandler" />
            </Style.Resources>
            <Setter Property="(i:Interaction.Behaviors)">
                <i:BehaviorCollectionTemplate>
                    <i:BehaviorCollection>
                        <ContextDropBehavior Handler="{StaticResource ModsListBoxDropHandler}" />
                    </i:BehaviorCollection>
                </i:BehaviorCollectionTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Border.mod-drag-handle">
            <Setter Property="(i:Interaction.Behaviors)">
                <i:BehaviorCollectionTemplate>
                    <i:BehaviorCollection>
                        <ContextDragBehavior HorizontalDragThreshold="3" VerticalDragThreshold="3" />
                    </i:BehaviorCollection>
                </i:BehaviorCollectionTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem.DraggingUp">
            <Setter Property="AdornerLayer.Adorner">
                <Template>
                    <Border BorderThickness="0 2 0 0"
                            BorderBrush="#2563EB"
                            IsHitTestVisible="False" />
                </Template>
            </Setter>
        </Style>

        <Style Selector="ListBox.ModsDragAndDrop ListBoxItem.DraggingDown">
            <Setter Property="AdornerLayer.Adorner">
                <Template>
                    <Border BorderThickness="0 0 0 2"
                            BorderBrush="#2563EB"
                            IsHitTestVisible="False" />
                </Template>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid Margin="12" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <TextBlock Text="Mod 管理" FontSize="22" FontWeight="Bold"/>

        <TextBlock Grid.Row="1"
                   Text="在这里可以查看已导入的 Mod、调整启用状态与拖拽调整加载顺序，并查看当前选中 Mod 的详细信息。"
                   Classes="secondary-text"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2" ColumnDefinitions="380,*" ColumnSpacing="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock Text="Mod 列表" FontSize="16" FontWeight="Bold"/>
                <ListBox x:Name="ModsListBox"
                         Grid.Row="1"
                         Classes="ModsDragAndDrop"
                         ItemsSource="{Binding HomePage.Mods}"
                         SelectedItem="{Binding HomePage.SelectedMod}"
                         DoubleTapped="OnModsListDoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="8" RowSpacing="2">
                                <CheckBox Grid.RowSpan="2"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Top"
                                          Margin="0,1,0,0"/>
                                <Border Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Classes="mod-drag-handle"
                                        Background="Transparent">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding ModId, StringFormat=ID: {0}}"
                                                   Classes="secondary-text"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="10">
                <TextBlock Text="Mod 详情" FontSize="16" FontWeight="Bold"/>

                <Border Grid.Row="1" Classes="card" Padding="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="基本信息" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding HomePage.SelectedMod.DisplayName, FallbackValue=未选择 Mod}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding HomePage.SelectedMod.ModId, StringFormat=ID: {0}}" Classes="secondary-text"/>
                        <TextBlock Text="{Binding HomePage.SelectedMod.ModRootPath, StringFormat=目录: {0}}"
                                   Classes="secondary-text"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Classes="card" Padding="10">
                    <Grid RowDefinitions="Auto,*" RowSpacing="6">
                        <TextBlock Text="描述信息" FontWeight="SemiBold"/>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding HomePage.SelectedMod.Description}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

